<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.sentinelsquad</string>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>WorkingDirectory</key>
  <string>__REPO_ROOT__/apps/sentinelsquad</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/bash</string>
    <string>__REPO_ROOT__/apps/sentinelsquad/scripts/launcher/sentinelsquad-daemon.sh</string>
  </array>
  <key>StandardOutPath</key>
  <string>__HOME__/Library/Logs/SentinelSquad/sentinelsquad.log</string>
  <key>StandardErrorPath</key>
  <string>__HOME__/Library/Logs/SentinelSquad/sentinelsquad.log</string>
</dict>
</plist>
