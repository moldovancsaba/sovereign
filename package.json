{
  "name": "sovereign-repo",
  "private": true,
  "version": "1.1.0",
  "description": "{sovereign} product repository",
  "workspaces": [
    "apps/sovereign"
  ],
  "scripts": {
    "install:app": "npm --prefix apps/sovereign install",
    "dev": "npm --prefix apps/sovereign run dev",
    "build": "npm --prefix apps/sovereign run build",
    "typecheck": "npm --prefix apps/sovereign run typecheck",
    "verify": "npm run typecheck && npm --prefix apps/sovereign run e2e:render-contract && npm --prefix apps/sovereign run e2e:mcp-docs && npm run build",
    "start": "npm --prefix apps/sovereign run start",
    "worker": "npm --prefix apps/sovereign run worker",
    "desktop:bootstrap": "npm --prefix tools/theia-desktop run bootstrap",
    "desktop:build": "npm --prefix tools/theia-desktop run build",
    "desktop:start": "npm --prefix tools/theia-desktop run start",
    "desktop:watch": "npm --prefix tools/theia-desktop run watch",
    "desktop:install-app": "bash tools/macos/SovereignDesktop/install_SovereignDesktop.sh",
    "menubar:install": "bash tools/macos/SovereignMenubar/install_SovereignMenubar.sh",
    "service:install": "bash apps/sovereign/scripts/launcher/sovereign-daemon-install.sh",
    "service:status": "bash apps/sovereign/scripts/launcher/sovereign-daemon-status.sh",
    "service:uninstall": "bash apps/sovereign/scripts/launcher/sovereign-daemon-uninstall.sh",
    "prisma:generate": "npm --prefix apps/sovereign run prisma:generate",
    "prisma:migrate": "npm --prefix apps/sovereign run prisma:migrate",
    "prisma:migrate:deploy": "npm --prefix apps/sovereign run prisma:migrate:deploy",
    "db:up": "docker compose up -d sovereign-db",
    "db:down": "docker compose stop sovereign-db",
    "install:macos": "bash scripts/install-sovereign-macos.sh",
    "bootstrap": "npm run install:app && npm run prisma:generate",
    "memory:verify": "npm --prefix apps/sovereign run memory:verify"
  }
}
