# App
# Direct local app runs use port 3007 (`npm run dev` / `npm run start`).
# Docker compose publishes the app on port 3577 by default.
NEXTAUTH_URL=http://localhost:3007
NEXTAUTH_SECRET=change-me-please
NEXT_PUBLIC_SENTINELSQUAD_LOCAL_AUTH_BYPASS=true
SENTINELSQUAD_LOCAL_AUTH_BYPASS=true

# GitHub OAuth (login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database
# Default docker-compose mapping publishes Postgres on localhost:34765.
DATABASE_URL=postgresql://sentinelsquad:sentinelsquad@localhost:34765/sentinelsquad?schema=public

# GitHub GraphQL token (service token for board reads/writes)
# Needs access to read/write ProjectsV2 and read repo issues.
SENTINELSQUAD_GITHUB_TOKEN=
SENTINELSQUAD_GITHUB_PROJECT_OWNER=moldovancsaba
SENTINELSQUAD_GITHUB_PROJECT_NUMBER=1
SENTINELSQUAD_TASK_REPO_OWNER=moldovancsaba
SENTINELSQUAD_TASK_REPO_NAME=sentinelsquad
SENTINELSQUAD_DASHBOARD_PRODUCT=SentinelSquad

# Optional: local worker settings (task runner)
SENTINELSQUAD_WORKER_AGENT_KEY=Controller
SENTINELSQUAD_WORKER_POLL_MS=1200
SENTINELSQUAD_WORKER_RUNTIME=LOCAL
SENTINELSQUAD_WORKER_MODEL=Granite-4.0-H-1B
SENTINELSQUAD_WORKER_HOST=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=Granite-4.0-H-1B

# Optional: OpenAI runtime for cloud agents (for example Chappie)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-nano
OPENAI_API_KEY=

# Optional: local-only dev login (avoid OAuth while bootstrapping)
SENTINELSQUAD_DEV_LOGIN_EMAIL=
SENTINELSQUAD_DEV_LOGIN_PASSWORD=

# Optional: RBAC baseline for privileged SentinelSquad actions.
# Role resolution order: ADMIN -> OPERATOR -> VIEWER -> CLIENT.
# If email is not listed in any role list, SENTINELSQUAD_RBAC_DEFAULT_ROLE is applied.
SENTINELSQUAD_RBAC_ADMIN_EMAILS=
SENTINELSQUAD_RBAC_OPERATOR_EMAILS=
SENTINELSQUAD_RBAC_VIEWER_EMAILS=
SENTINELSQUAD_RBAC_CLIENT_EMAILS=
SENTINELSQUAD_RBAC_DEFAULT_ROLE=OPERATOR
