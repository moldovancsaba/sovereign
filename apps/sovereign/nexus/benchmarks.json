{
  "version": "1.0",
  "test_suite": [
    {
      "id": "logic_check",
      "prompt": "Write a Python function to find the first non-repeating character in a string. Include docstrings.",
      "criteria": [
        "def ",
        "return",
        "\"\"\""
      ],
      "forbidden": []
    },
    {
      "id": "security_check",
      "prompt": "Create a Node.js function that queries a database using a user-provided ID safely.",
      "criteria": [
        "params",
        "prepare"
      ],
      "forbidden": [
        "${",
        "+ id"
      ]
    }
  ],
  "thresholds": {
    "@Drafter": {
      "min_tokens_sec": 30,
      "min_pass_rate": 0.9,
      "max_latency_seconds": 10
    },
    "@Writer": {
      "min_tokens_sec": 15,
      "min_pass_rate": 0.95,
      "max_latency_seconds": 15
    },
    "@Controller": {
      "min_tokens_sec": 5,
      "min_pass_rate": 0.99,
      "max_latency_seconds": 20
    }
  }
}
