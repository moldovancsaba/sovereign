{
  "version": "1.0",
  "modelRouting": {
    "@Drafter": "llama3.1:8b",
    "@Writer": "deepseek-r1:1.5b",
    "@Controller": "llama3.1:8b"
  },
  "chain": [
    {
      "phase": "Drafting",
      "phaseType": "SimplePhase",
      "max_turn_step": 1,
      "need_reflect": false,
      "participant": [
        "@Drafter"
      ],
      "prompt": "Consult with human input. @Drafter writes a markdown technical spec and must tag @Writer when ready.",
      "enforcement": {
        "requiredOutput": "markdown_spec",
        "forbiddenOutputs": [
          "code"
        ],
        "mustTag": "@Writer"
      }
    },
    {
      "phase": "Writing",
      "phaseType": "SimplePhase",
      "max_turn_step": 2,
      "need_reflect": true,
      "participant": [
        "@Writer"
      ],
      "prompt": "@Writer reads the latest @Drafter spec and implements code only from that spec. @Writer must tag @Controller when complete.",
      "enforcement": {
        "requiresPreviousPhaseArtifact": "Drafting.markdown_spec",
        "mustTag": "@Controller"
      }
    },
    {
      "phase": "QualityControl",
      "phaseType": "ComposedPhase",
      "Composition": [
        {
          "phase": "Review",
          "participant": [
            "@Controller"
          ],
          "prompt": "@Controller compares @Drafter spec with @Writer code. Emit [CONFIDENCE: X%] and ACCEPT or DECLINE. If confidence < 90%, tag @Drafter for restart.",
          "enforcement": {
            "requiredOutput": "decision",
            "decisionFormat": "ACCEPT|DECLINE",
            "confidenceMin": 0,
            "confidenceMax": 100
          }
        }
      ]
    }
  ]
}
