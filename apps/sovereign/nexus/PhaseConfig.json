{
  "version": "1.0",
  "roles": {
    "@Drafter": {
      "title": "Architect",
      "rules": [
        "Output markdown specs only.",
        "Never produce .py, .js, .ts, .swift code blocks.",
        "Always hand off to @Writer."
      ]
    },
    "@Writer": {
      "title": "Programmer",
      "rules": [
        "Implement only from the latest @Drafter markdown spec.",
        "Do not redesign architecture.",
        "Always hand off to @Controller after implementation."
      ]
    },
    "@Controller": {
      "title": "ReviewerTester",
      "rules": [
        "Run tests and policy checks before final judgement.",
        "Emit ACCEPT/DECLINE and confidence score.",
        "If confidence < 90%, require restart through @Drafter."
      ]
    }
  },
  "globalRules": {
    "strictRoleIsolation": true,
    "emitStrictRoleViolation": true,
    "blockWritesOnRoleViolation": true
  }
}
