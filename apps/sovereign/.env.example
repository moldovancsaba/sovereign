# App
# Direct local app runs use port 3007 (`npm run dev` / `npm run start`).
# Docker compose publishes the app on port 3577 by default.
NEXTAUTH_URL=http://localhost:3007
NEXTAUTH_SECRET=change-me-please
NEXT_PUBLIC_SOVEREIGN_LOCAL_AUTH_BYPASS=true
SOVEREIGN_LOCAL_AUTH_BYPASS=true

# GitHub OAuth (login)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Database
# Default docker-compose mapping publishes Postgres on localhost:34765.
DATABASE_URL=postgresql://sovereign:sovereign@localhost:34765/sovereign?schema=public

# GitHub GraphQL token (service token for board reads/writes)
# Needs access to read/write ProjectsV2 and read repo issues.
SOVEREIGN_GITHUB_TOKEN=
SOVEREIGN_GITHUB_PROJECT_OWNER=moldovancsaba
SOVEREIGN_GITHUB_PROJECT_NUMBER=1
SOVEREIGN_TASK_REPO_OWNER=moldovancsaba
SOVEREIGN_TASK_REPO_NAME=sovereign
SOVEREIGN_DASHBOARD_PRODUCT=Sovereign

# Optional: filesystem tool workspace (colon-separated roots on POSIX).
# SOVEREIGN_WORKSPACE_ROOT=
# SOVEREIGN_LOCAL_PROJECT_ROOT=

# Optional: local worker settings (task runner)
SOVEREIGN_WORKER_AGENT_KEY=Controller
SOVEREIGN_WORKER_POLL_MS=1200
SOVEREIGN_WORKER_RUNTIME=LOCAL
SOVEREIGN_WORKER_MODEL=Granite-4.0-H-1B
SOVEREIGN_WORKER_HOST=
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=Granite-4.0-H-1B

# LLD-006 semantic memory (768-d; default nomic-embed-text). Requires pgvector in Postgres.
# SOVEREIGN_EMBEDDING_MODEL=nomic-embed-text
# SOVEREIGN_MEMORY_EMBED_ON_CAPTURE=1
# Worker prompt memory: default THREAD (chat). Use task payload memory.scope=PROJECT_SESSION for durable ProjectMemory.
# SOVEREIGN_MEMORY_QUERY_MAX_CHARS=280
# SOVEREIGN_STRICT_ORCHESTRATION=1
# SOVEREIGN_ORCH_CONTROLLER_KEY=Controller

# Optional: OpenAI runtime for cloud agents (for example Chappie)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4.1-nano
OPENAI_API_KEY=

# Optional: MLX OpenAI-compatible provider scaffold (Issue #15).
# SOVEREIGN_MLX_BASE_URL=http://127.0.0.1:8080/v1
# SOVEREIGN_MLX_MODEL=mlx-community/Qwen2.5-7B-Instruct-4bit
# SOVEREIGN_MLX_API_KEY=

# Optional: Sovereign API v1 runtime guards and staffing calibration.
# SOVEREIGN_API_TOKEN=
# SOVEREIGN_API_MAX_BODY_BYTES=262144
# SOVEREIGN_API_PROVIDER_TIMEOUT_MS=60000
# SOVEREIGN_STAFFING_WEIGHT_QUALITY=0.35
# SOVEREIGN_STAFFING_WEIGHT_ROLE_FIT=0.22
# SOVEREIGN_STAFFING_WEIGHT_LATENCY=0.18
# SOVEREIGN_STAFFING_WEIGHT_COST=0.10
# SOVEREIGN_STAFFING_WEIGHT_RELIABILITY=0.05
# SOVEREIGN_STAFFING_WEIGHT_RANKING_BOOST=0.10

# Optional: local-only dev login (avoid OAuth while bootstrapping)
SOVEREIGN_DEV_LOGIN_EMAIL=
SOVEREIGN_DEV_LOGIN_PASSWORD=

# Optional: wiki bridge for MCP docs + ingest (LLD-007). Set SOVEREIGN_WIKI_TYPE to bookstack OR outline.
#
# BookStack: "Access system API" on the token role.
# SOVEREIGN_WIKI_TYPE=bookstack
# SOVEREIGN_WIKI_BASE_URL=http://127.0.0.1:6875
# SOVEREIGN_WIKI_TOKEN_ID=
# SOVEREIGN_WIKI_TOKEN_SECRET=
#
# Outline (getoutline.com): API key from workspace Settings → API keys (documents.* scope).
# SOVEREIGN_WIKI_TYPE=outline
# SOVEREIGN_WIKI_BASE_URL=https://your-outline.example.com
# SOVEREIGN_WIKI_API_KEY=
# If your instance expects the key in JSON body instead of Bearer: SOVEREIGN_WIKI_OUTLINE_TOKEN_IN_BODY=1
#
# SOVEREIGN_WIKI_MCP_PAGE_LIMIT=60

# Optional: email ingress webhook (POST /api/ingress/email). If unset, ingress auth is skipped.
# SOVEREIGN_EMAIL_INGRESS_TOKEN=

# Optional: RBAC baseline for privileged actions.
# Role resolution order: ADMIN -> OPERATOR -> VIEWER -> CLIENT.
# If email is not listed in any role list, SOVEREIGN_RBAC_DEFAULT_ROLE is applied.
SOVEREIGN_RBAC_ADMIN_EMAILS=
SOVEREIGN_RBAC_OPERATOR_EMAILS=
SOVEREIGN_RBAC_VIEWER_EMAILS=
SOVEREIGN_RBAC_CLIENT_EMAILS=
SOVEREIGN_RBAC_DEFAULT_ROLE=OPERATOR
